{
  "audio": {
    "sample_rate": 44100,
    "n_fft": 2048,
    "hop_length": 256,
    "chunk_seconds": 3.0
  },
  "model": {
    "d_model": 256,
    "n_heads": 4,
    "n_encoder_layers": 4,
