# Preset configs intentionally omit machine-specific runtime paths.
# Set them here or override them at launch with:
#   --data_dirs
#   --output_dir
#   --checkpoint
# Example values:
# INSTR_DATA_DIRS=./data
# INSTR_OUTPUT_DIR=./outputs
INSTR_DATA_DIRS=
INSTR_OUTPUT_DIR=
INSTR_CHECKPOINT_PATH=

INSTR_ENABLE_WANDB=false
INSTR_WANDB_PROJECT=
INSTR_WANDB_ENTITY=
INSTR_WANDB_API_KEY=

INSTR_ENABLE_S3=false
INSTR_AWS_REGION=us-east-1
INSTR_S3_BUCKET=
INSTR_S3_CHECKPOINT_PREFIX=checkpoints
