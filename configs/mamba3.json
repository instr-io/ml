    "n_bottleneck_layers": 6,
    "dropout": 0.0,
    "d_state": 32,
    "use_mid_side": false,
    "ssm_variant": "mamba3",
    "d_conv": 4,
    "expand": 2,
    "mamba3_headdim": 64,
    "mamba3_is_mimo": false,
